# Centinela environment template. Copy to .env and fill in.
# .env is gitignored and must never be committed.
#
# To run the app locally with no Google Cloud access, set TESTING=true and
# leave the rest blank: the backend uses in-memory fallbacks and mock data.

# Local mode: use in-memory fallbacks instead of live Google Cloud services.
TESTING=true

# Google Cloud project that owns BigQuery, Firestore, Vertex AI, Translation,
# Text-to-Speech, and Firebase Cloud Messaging.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Vertex AI (the Gemini agent and narration). Keep consistent with
# your project resources.
GOOGLE_CLOUD_LOCATION=us

# Google Weather and Air Quality API key (observed rain + air quality).
GOOGLE_WEATHER_API_KEY=your-google-weather-api-key

# Command used to launch the Fivetran MCP server that the DataOps agent calls.
FIVETRAN_MCP_COMMAND=your-fivetran-mcp-launch-command

# Fully qualified BigQuery table for the raw seismic events feed.
SEISMIC_RAW_EVENTS_TABLE=project.dataset.seismic_raw_events

# Notes:
# - Fivetran API keys are NOT set here. They live in Google Secret Manager.
# - On Cloud Run, BigQuery / Firestore / Vertex / Translation / TTS are reached
#   through the runtime service account, so those credentials are not env vars.
# - The Google Maps and Firebase web keys live in the client code and are
#   public, HTTP-referrer restricted to the deployment domain.
